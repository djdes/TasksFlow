DATABASE_URL="postgresql://user:password@localhost:5432/haccp_online"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Source-site scraping (legacy import)
SOURCE_SITE_LOGIN_URL="https://lk.haccp-online.ru/docs/login"
SOURCE_SITE_START_URL="https://lk.haccp-online.ru/docs/1"
SOURCE_SITE_USERNAME=""
SOURCE_SITE_PASSWORD=""

# Telegram integration
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_LINK_TOKEN_SECRET=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_LOG_RETENTION_DAYS="30"
# Optional — in regions where api.telegram.org is blocked (RU), set this to a
# reverse-proxy URL (e.g. Cloudflare Worker that forwards /bot*/* → telegram).
# Example: https://tg-proxy.<you>.workers.dev   (no trailing /)
TELEGRAM_API_ROOT=""

# Email (Resend / SMTP)
RESEND_API_KEY=""
SMTP_FROM=""

# Platform ROOT superadmin bootstrap (seeded by prisma/seed.ts).
# Set PLATFORM_ORG_ID once; changing it after first seed orphans the old row.
# Use ROOT_PASSWORD (plain) — .env parsing (dotenv / Next.js @next/env)
# interprets `$` characters, which mangles a bcrypt hash like $2b$12$...
# into an unusable string. Plain password is hashed by seed.ts itself.
PLATFORM_ORG_ID="platform"
ROOT_EMAIL=""
ROOT_PASSWORD=""
# Only use ROOT_PASSWORD_HASH if you know your env loader does NOT interpolate
# `$` sequences. Most (dotenv-expand, @next/env) do — stick with ROOT_PASSWORD.
ROOT_PASSWORD_HASH=""

# Registration wizard rate limit + email verification
EMAIL_VERIFICATION_TTL_MIN="10"
REGISTER_RATE_LIMIT="5"
