# Database (MySQL)
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=tasksflow

# Server
PORT=5001
SESSION_SECRET=your_random_secret_key_here_minimum_32_chars

# Email notifications (optional). Если все три SMTP_HOST/USER/PASS
# не заданы — email-уведомления о выполненных задачах не отправляются
# (silent skip с warning в логе на старте). Для Gmail: используйте
# App Password (Google Account → Security → App passwords), не
# основной пароль аккаунта.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM='"TasksFlow" <noreply@yourcompany.ru>'
# DEFAULT_ADMIN_EMAIL=admin@example.com

# Базовый URL приложения для генерации ссылок-приглашений (/join/<token>).
# Если не задан — берётся из заголовков запроса (req.protocol + Host).
# PUBLIC_BASE_URL=https://tasksflow.example.com
