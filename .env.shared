# ============================================================
# HACCP-Online — shared secrets for all developers
# Скопируй в .env: cp .env.shared .env
# ============================================================

# === ЛОКАЛЬНАЯ РАЗРАБОТКА ===
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/haccp_online?sslmode=disable"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-change-in-prod-32chars!!"

# === ПРОДАКШН СЕРВЕР ===
# Хостинг: FastPanel, Ubuntu 24.04, Azure
# Приложение: ~/www/haccp.magday.ru/app (PM2, port 3001)
# Домен: https://haccp.magday.ru
#
# Продакшн .env настраивается на сервере вручную.
# SSH и DB креденшалы хранятся отдельно (не в репозитории).

# === TUYA IOT (общие для дев и прод) ===
TUYA_ACCESS_ID=""
TUYA_ACCESS_SECRET=""
TUYA_BASE_URL="https://openapi.tuyaeu.com"
TUYA_CRON_SECRET=""
# Датчик: bf397860f79b0963a0nakc (модель SNT957W-DE, WiFi, temp+humidity)

# === AI / OCR (распознавание этикеток с фото) ===
# Используется Claude Haiku для анализа фото этикеток
# Получить ключ: https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# === TELEGRAM ===
# Бот: @wesetupbot
# Webhook: https://haccp.magday.ru/api/notifications/telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME="wesetupbot"
TELEGRAM_WEBHOOK_SECRET=""

# === CRON (для ежедневной проверки заполнения журналов) ===
CRON_SECRET=""

# === SMTP (для прод — localhost:25, для дев — оставь пустым) ===
SMTP_HOST=""
SMTP_PORT=""
SMTP_FROM=""
