generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                   String            @id @default(cuid())
  name                 String
  type                 String
  inn                  String?
  address              String?
  phone                String?
  subscriptionPlan     String            @default("trial")
  subscriptionEnd      DateTime?
  locale               String            @default("ru")
  brandColor           String?
  logoUrl              String?
  yookassaShopId       String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  /// Per-organisation bearer token for POST /api/external/entries. When set,
  /// overrides the shared EXTERNAL_API_TOKEN env and resolves the caller's
  /// organizationId automatically. Keep unique across orgs.
  externalApiToken     String?           @unique
  /// Journal template codes the organization has chosen NOT to keep. Empty
  /// by default (= all 35 journals enabled). Toggled from /settings/journals
  /// so different production profiles (кафе, мясокомбинат, пекарня…) can
  /// hide the journals that don't apply. Disabled journals are muted in
  /// the browser and excluded from dashboard compliance counts.
  disabledJournalCodes Json              @default("[]")
  /// Journal template codes enabled for auto document creation. Every
  /// day a cron checks for codes in this list and ensures there is an
  /// active JournalDocument covering today; creates a month-long doc if
  /// missing. Manages via /settings/auto-journals.
  autoJournalCodes     Json              @default("[]")
  users                User[]
  areas                Area[]
  journalEntries       JournalEntry[]
  products             Product[]
  auditLogs            AuditLog[]
  batches              Batch[]
  capaTickets          CapaTicket[]
  lossRecords          LossRecord[]
  productionPlans      ProductionPlan[]
  changeRequests       ChangeRequest[]
  staffCompetencies    StaffCompetency[]
  journalDocuments     JournalDocument[]
  jobPositions         JobPosition[]
  notifications        Notification[]
  botInviteTokens      BotInviteToken[]
  journalObligations   JournalObligation[]
}

model User {
  id                    String              @id @default(cuid())
  email                 String              @unique
  name                  String
  phone                 String?
  passwordHash          String
  role                  String              @default("cook")
  // Free-form job title that overrides the role-based label in journals.
  // Lets the same "cook" role user be displayed as "Повар холодного цеха" or
  // "Официант" per employee, instead of flipping between journals.
  positionTitle         String?
  organizationId        String
  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  telegramChatId        String?
  notificationPrefs     Json?
  isActive              Boolean             @default(true)
  // Platform-level superadmin flag. Orthogonal to `role` (which is the in-org
  // job title). Root users still belong to a real `Organization`; the synthetic
  // "platform" org carries them so every existing FK/query keeps working.
  isRoot                Boolean             @default(false)
  // False until the owner has explicitly edited this user's journal ACL in
  // /settings/users. While false, `hasJournalAccess` grants all journals —
  // this gives zero-regression behaviour for employees predating the ACL.
  journalAccessMigrated Boolean             @default(false)
  // Soft-archive marker for the staff page. When set, the user disappears
  // from active lists + can no longer log in, but stays referenced by old
  // journal entries. Separate from `isActive` so the staff screen can
  // distinguish "uploaded an employee but disabled them" from "formally
  // dismissed / transferred to archive".
  archivedAt            DateTime?
  // Structured job position reference. Optional — existing rows keep their
  // free-form `positionTitle` until the seed migration buckets them into
  // per-org `JobPosition` rows. New UI writes only `jobPositionId`; legacy
  // UI continues to read `positionTitle` via the getUserDisplayTitle helper.
  jobPositionId         String?
  jobPosition           JobPosition?        @relation(fields: [jobPositionId], references: [id], onDelete: SetNull)
  createdAt             DateTime            @default(now())
  /// Personal permission override — JSON-массив кодов из
  /// src/lib/permissions.ts. null = наследовать от должности/группы.
  /// Индивидуальный override используется редко: «этот конкретный
  /// официант умеет принимать поставки и его надо пустить в batches».
  permissionsJson       Json?
  journalEntries        JournalEntry[]
  journalAccess         UserJournalAccess[]
  inviteToken           InviteToken?
  botInviteToken        BotInviteToken?
  workOffDays           StaffWorkOffDay[]
  vacations             StaffVacation[]
  sickLeaves            StaffSickLeave[]
  dismissal             StaffDismissal?
  notifications         Notification[]
  journalObligations    JournalObligation[]

  @@index([organizationId, archivedAt])
  @@index([jobPositionId])
}

/// A custom job title (должность) an organisation has chosen to use.
/// `categoryKey` groups positions into the two columns from the staff page —
/// "management" (Руководство) and "staff" (Сотрудники). `sortOrder` lets the
/// owner drag positions around; unique (org, category, name) keeps duplicates
/// out.
model JobPosition {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// "management" | "staff"
  categoryKey    String
  name           String
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  users          User[]
  /// JSON-массив permission-кодов (см. src/lib/permissions.ts). null =
  /// наследовать defaults группы (management/staff). Override для
  /// конкретной должности: «пекари тоже могут редактировать график».
  permissionsJson Json?

  @@unique([organizationId, categoryKey, name])
  @@index([organizationId, sortOrder])
}

/// Hygiene-journal autofill input: a day the employee is off duty.
model StaffWorkOffDay {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Day at 00:00 UTC — stored as DateTime for Prisma friendliness.
  date      DateTime
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

/// Vacation period (график отпусков) — inclusive on both ends.
model StaffVacation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateFrom  DateTime
  dateTo    DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([dateFrom, dateTo])
}

/// Sick-leave period (график больничных) — inclusive on both ends.
model StaffSickLeave {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateFrom  DateTime
  dateTo    DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([dateFrom, dateTo])
}

/// Formal dismissal record (график увольнений). Unique per user — a single
/// dismissal is enough; if the employee is re-hired, remove the row + unarchive.
model StaffDismissal {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  createdAt DateTime @default(now())

  @@index([date])
}

/// Invite flow token. Created alongside a placeholder `User` when an owner
/// invites a new employee; mailed to them as /invite/<token> URL. The user
/// clicks, sets their password, and the token is marked `usedAt`.
///
/// `tokenHash` is a bcrypt/sha256 digest of the raw token — raw value never
/// persisted, so a DB leak cannot produce usable invite links.
model InviteToken {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
}

/// Invite tokens for the Telegram-first onboarding flow (Mini App Stage 1).
/// Separate from `InviteToken` because semantics differ: `InviteToken` means
/// "set a password on the site", this one means "bind your Telegram identity".
/// Consumed by the grammy `/start inv_<token>` handler, which resolves the
/// token, writes `telegramChatId` on the matching User and activates them.
model BotInviteToken {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash      String       @unique
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([expiresAt])
}

/// Per-journal access grant for an employee. Rows only exist for explicit
/// grants; absence = no access (after `User.journalAccessMigrated` flips to
/// true). Managers / root bypass this table entirely.
model UserJournalAccess {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateCode String
  canRead      Boolean  @default(true)
  canWrite     Boolean  @default(true)
  canFinalize  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, templateCode])
  @@index([userId])
}

model Area {
  id             String         @id @default(cuid())
  name           String
  description    String?
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  equipment      Equipment[]
  journalEntries JournalEntry[]
}

model Equipment {
  id             String         @id @default(cuid())
  name           String
  type           String
  serialNumber   String?
  tempMin        Float?
  tempMax        Float?
  tuyaDeviceId   String?
  areaId         String
  area           Area           @relation(fields: [areaId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]
}

/// Long-form article for the public /blog. Platform-level (not org-scoped)
/// — edited by ROOT in /root/blog and displayed to any visitor. Body is
/// structured as a JSON-serialized array of typed blocks
/// (paragraph / heading / list / quote) so we never have to ship a Markdown
/// parser or sanitise arbitrary HTML.
model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  /// ArticleBlock[] — see src/lib/article-blocks.ts
  body        Json
  coverIcon   String?
  tags        String[]  @default([])
  readMinutes Int       @default(5)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([publishedAt])
}

/// User-submitted feedback from the in-app "Оставить обратную связь" modal.
/// Stored without FK relations on purpose: we keep a snapshot of userId /
/// email / name / org at submission time so reports stay readable after a
/// user or organisation is later deleted.
model FeedbackReport {
  id               String   @id @default(cuid())
  userId           String?
  userEmail        String?
  userName         String?
  organizationId   String?
  organizationName String?
  /// "bug" | "suggestion"
  type             String
  message          String
  phone            String?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([type])
}

/// In-app notifications that surface state-drift hints ("add these new
/// employees to hygiene journal", etc). Each row is scoped to a recipient
/// user inside an organisation and carries a typed payload in `items`.
///
/// We persist read/dismiss on the same row so the «Прочитанные» tab can
/// list history without a separate join table. `items` is a JSON array of
/// small objects that the client renders as a checkbox list — the shape
/// is typed in src/lib/notifications.ts.
model Notification {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Domain tag — e.g. "staff.added.journal". Used to dedupe with `key`.
  kind           String
  /// Stable dedupe key (e.g. "staff.added.journal:<journalCode>") so
  /// repeated triggers merge items into the existing open notification
  /// instead of piling up duplicates.
  dedupeKey      String
  title          String
  /// Optional inline link target, e.g. "/journals/hygiene".
  linkHref       String?
  linkLabel      String?
  items          Json      @default("[]")
  readAt         DateTime?
  dismissedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, dedupeKey])
  @@index([userId, dismissedAt, readAt])
  @@index([organizationId])
}

model JournalObligation {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId     String
  template       JournalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  journalCode    String
  kind           String          @default("daily-journal")
  dateKey        DateTime
  status         String          @default("pending")
  targetPath     String
  source         String          @default("daily-journal-sync")
  dedupeKey      String
  openedAt       DateTime?
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([userId, dedupeKey])
  @@index([userId, dateKey, status])
  @@index([organizationId, dateKey, status])
  @@index([templateId])
}

model JournalTemplate {
  id                 String            @id @default(cuid())
  code               String            @unique
  name               String
  description        String?
  fields             Json
  isActive           Boolean           @default(true)
  sortOrder          Int               @default(0)
  isMandatorySanpin  Boolean           @default(false)
  isMandatoryHaccp   Boolean           @default(false)
  entries            JournalEntry[]
  documents          JournalDocument[]
  journalObligations JournalObligation[]
}

model Product {
  id             String       @id @default(cuid())
  name           String
  supplier       String?
  barcode        String?
  unit           String       @default("kg")
  category       String?
  storageTemp    String?
  shelfLifeDays  Int?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, name])
  @@index([organizationId, barcode])
}

model JournalEntry {
  id             String          @id @default(cuid())
  templateId     String
  template       JournalTemplate @relation(fields: [templateId], references: [id])
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  areaId         String?
  area           Area?           @relation(fields: [areaId], references: [id])
  equipmentId    String?
  equipment      Equipment?      @relation(fields: [equipmentId], references: [id])
  filledById     String
  filledBy       User            @relation(fields: [filledById], references: [id])
  data           Json
  status         String          @default("submitted")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId, templateId, createdAt])
  @@index([filledById])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  userName       String?
  action         String
  entity         String
  entityId       String?
  details        Json?
  ipAddress      String?
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([entity, entityId])
}

/// Ephemeral email verification codes used by the multi-step registration
/// wizard (/register -> /register/verify). `codeHash` is a bcrypt digest of
/// the 6-digit code; raw code is only present in the outgoing email.
/// `attempts` blocks brute-force guessing.
model EmailVerification {
  id        String   @id @default(cuid())
  email     String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

/// Audit log for every outgoing Telegram message. 30-day retention (cron).
/// Status transitions:
///   queued -> sent            (normal path)
///   queued -> failed          (non-429 Telegram error; `error` populated)
///   queued -> rate_limited    (429 after max retries)
model TelegramLog {
  id        String    @id @default(cuid())
  userId    String?
  organizationId String?
  chatId    String
  body      String
  kind      String?
  dedupeKey String?
  status    String    @default("queued")
  error     String?
  attempts  Int       @default(0)
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, organizationId, kind, dedupeKey, createdAt])
  @@index([status, createdAt])
}

model Batch {
  id             String       @id @default(cuid())
  code           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productName    String
  supplier       String?
  quantity       Float
  unit           String       @default("kg")
  receivedAt     DateTime     @default(now())
  expiryDate     DateTime?
  status         String       @default("received")
  sourceEntryId  String?
  notes          String?
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@index([organizationId, expiryDate])
}

model CapaTicket {
  id                 String       @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title              String
  description        String?
  priority           String       @default("medium")
  status             String       @default("open")
  category           String       @default("other")
  sourceType         String?
  sourceEntryId      String?
  assignedToId       String?
  dueDate            DateTime?
  slaHours           Int          @default(24)
  rootCause          String?
  correctiveAction   String?
  preventiveAction   String?
  verificationResult String?
  resolvedAt         DateTime?
  closedAt           DateTime?
  createdById        String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, priority])
}

model LossRecord {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date           DateTime     @default(now())
  category       String
  productName    String
  quantity       Float
  unit           String       @default("kg")
  costRub        Float?
  cause          String?
  areaId         String?
  createdById    String?
  createdAt      DateTime     @default(now())

  @@index([organizationId, date])
  @@index([organizationId, category])
}

model ProductionPlan {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date           DateTime
  shift          String       @default("morning")
  items          Json
  status         String       @default("draft")
  notes          String?
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, date, shift])
  @@index([organizationId, date])
}

model ChangeRequest {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title           String
  changeType      String
  description     String?
  riskAssessment  String?
  testBatchResult String?
  status          String       @default("requested")
  version         Int          @default(1)
  requestedById   String?
  approvedById    String?
  implementedAt   DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId, status])
}

model StaffCompetency {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  skill          String
  level          Int          @default(0)
  certifiedAt    DateTime?
  expiresAt      DateTime?
  certifiedById  String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId, skill])
  @@index([organizationId, userId])
}

// ============================================================
// Document-based journals (grid: employees × days)
// Each JournalDocument = one printable document covering a date range.
// JournalDocumentEntry = one cell in the grid (employee + date + data).
// ============================================================

model JournalDocument {
  id                String                 @id @default(cuid())
  templateId        String
  template          JournalTemplate        @relation(fields: [templateId], references: [id])
  organizationId    String
  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title             String // e.g. "Гигиенический журнал"
  config            Json?
  dateFrom          DateTime
  dateTo            DateTime
  responsibleUserId String?
  responsibleTitle  String? // e.g. "Управляющий"
  status            String                 @default("active") // active | closed
  autoFill          Boolean                @default(false)
  createdById       String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  entries           JournalDocumentEntry[]

  @@index([organizationId, templateId, status])
  @@index([organizationId, dateFrom])
}

model JournalDocumentEntry {
  id         String          @id @default(cuid())
  documentId String
  document   JournalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  employeeId String
  date       DateTime // the specific day (date-only, truncated to midnight)
  data       Json // template-specific: { healthStatus: "healthy"|"day_off"|..., temperatureAbove37: false }
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([documentId, employeeId, date])
  @@index([documentId, date])
}

// Stores responses keyed by Idempotency-Key header so retried POSTs to
// /api/external/entries return the same result without double-writing.
// TTL is enforced by a nightly job; do not rely on this table forever.
model JournalExternalIdempotency {
  key            String   @id
  organizationId String?
  journalCode    String?
  httpStatus     Int
  response       Json
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

// Audit log for every request hitting the external integration API.
// Keeps raw payload + outcome so we can debug upstream apps (employee app, sensor feed)
// without touching production logs.
model JournalExternalLog {
  id             String    @id @default(cuid())
  organizationId String?
  journalCode    String?
  date           DateTime?
  source         String? // e.g. "employee_app" | "sensor" | "manual"
  tokenHint      String? // last 4 chars of token used
  httpStatus     Int
  status         String // "ok" | "error"
  errorMessage   String?
  documentId     String?
  entriesWritten Int       @default(0)
  payload        Json?
  createdAt      DateTime  @default(now())

  @@index([organizationId, createdAt])
  @@index([journalCode, createdAt])
}

/// Per-organization integration with TasksFlow (https://tasksflow.ru).
/// Stores the encrypted bearer key + base URL so WeSetup can push journal
/// rows as recurring tasks and receive completion events.
///
/// Encryption: `apiKeyEncrypted` is AES-256-GCM with INTEGRATION_KEY_SECRET.
/// `apiKeyPrefix` keeps the first 12 chars of the plaintext for UI display
/// ("tfk_abc123…") without exposing the secret.
///
/// One row per Organization — `organizationId @unique` enforces it.
model TasksFlowIntegration {
  id                  String    @id @default(cuid())
  organizationId      String    @unique
  baseUrl             String
  /// AES-256-GCM ciphertext: `iv(base64).tag(base64).ciphertext(base64)`.
  apiKeyEncrypted     String
  /// First 12 chars of the original plaintext, for UI ("tfk_abc12345").
  apiKeyPrefix        String
  /// TasksFlow companyId resolved during connect (`whoami` or first task call).
  /// Null means we haven't been able to resolve it yet.
  tasksflowCompanyId  Int?
  /// HMAC secret for the inbound webhook, generated on connect.
  webhookSecret       String
  enabled             Boolean   @default(true)
  lastSyncAt          DateTime?
  /// Free-form notes set by the integrator (e.g. "Test key", "Production").
  label               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  links               TasksFlowUserLink[]
  taskLinks           TasksFlowTaskLink[]

  @@index([organizationId])
}

/// Mapping between WeSetup `User` and a TasksFlow user (= worker). The
/// natural key is the phone number — TasksFlow logs in by phone, and we
/// auto-link any WeSetup user whose `phone` matches a TasksFlow user.
///
/// `tasksflowUserId` is nullable because we may have a phone match in
/// WeSetup before the cleaner has been imported into TasksFlow.
model TasksFlowUserLink {
  id                String                @id @default(cuid())
  integrationId     String
  integration       TasksFlowIntegration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  /// WeSetup user (employee). Cascade-deleted when the user is removed.
  wesetupUserId     String
  /// Normalized phone (`+7XXXXXXXXX`). Stored lowercase, no spaces, so we
  /// can match against TasksFlow regardless of how either side typed it.
  phone             String
  tasksflowUserId   Int?
  tasksflowWorkerId Int?
  /// "auto" = matched by phone on sync; "manual" = pinned by an admin
  /// (don't overwrite during the next auto-sync).
  source            String                @default("auto")
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([integrationId, wesetupUserId])
  @@index([integrationId, phone])
}

/// Records every task we created in TasksFlow on behalf of a WeSetup
/// journal row. Lets us update / delete / mark-complete the right
/// remote task without re-discovering it, and survives a journal row
/// edit (we update the existing TasksFlow task instead of orphaning it).
///
/// `journalDocumentId` + `rowKey` is the natural composite key on the
/// WeSetup side — `rowKey` is the journal-specific row identifier
/// (e.g. cleaning row id, or "<roomId>:<dateKey>" for matrix cells).
model TasksFlowTaskLink {
  id                  String                @id @default(cuid())
  integrationId       String
  integration         TasksFlowIntegration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  journalCode         String
  journalDocumentId   String
  rowKey              String
  tasksflowTaskId     Int
  /// Last status received from TasksFlow ("active" | "completed").
  remoteStatus        String                @default("active")
  /// When TasksFlow reported completion (mirrored back to journal cell).
  completedAt         DateTime?
  /// Last sync direction: "push" (WeSetup → TasksFlow) or "pull" (the
  /// other way). Pure observability, doesn't change behaviour.
  lastDirection       String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@unique([integrationId, journalDocumentId, rowKey])
  @@index([tasksflowTaskId])
}
